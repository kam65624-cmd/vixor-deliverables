+  endToken: TokenInfo;
+  inputAmount: bigint;
+  expectedOutput: bigint;
+  grossProfitBps: number;
+  netProfitBps: number;
+  estimatedGasLamports: number;
+  confidence: number;
+  detectedAt: number;
+  expiresAt: number;
+}
+
+export interface ExecutionResult {
